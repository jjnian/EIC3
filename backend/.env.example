# 数据库配置
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ontology_flow

# JWT配置
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 文件存储
UPLOAD_DIR=./uploads

# AI API Keys (可选，用户也可在前端配置)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
ZHIPU_API_KEY=
DASHSCOPE_API_KEY=